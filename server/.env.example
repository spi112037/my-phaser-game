PORT=8787
HOST=0.0.0.0
# Comma-separated allowlist, use * for open access during LAN testing.
CORS_ALLOW_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Optional: pin Comfy and Python paths
# Local ComfyUI (Windows)
# COMFY_API_BASE=http://127.0.0.1:8000
# Cloud-reachable ComfyUI (Railway should use this in production)
# COMFY_API_BASE=https://comfy.flamejourneygame.com
# COMFY_APP_DIR=D:\ComfyUI2\resources\ComfyUI
# PYTHON_EXE=C:\Users\user\Documents\ComfyUI\.venv\Scripts\python.exe
# For cloud Comfy endpoint on Railway, keep this false.
# COMFY_AUTO_START=false


