# ==========================
# Frontend (Vite)
# ==========================
# Public API base URL reachable by browser
VITE_API_BASE=https://api.flamejourneygame.com

# ==========================
# Backend (Node battle-api)
# ==========================
# Bind address/port (Railway can inject PORT automatically)
HOST=0.0.0.0
PORT=8787

# Comma-separated allowed origins for CORS
# Example for your domain:
CORS_ALLOW_ORIGINS=https://flamejourneygame.com,https://www.flamejourneygame.com

# IMPORTANT:
# For Vercel preview domains (*.vercel.app), set VITE_API_BASE explicitly.
# This server is battle-only; no Comfy/image env vars are required.
